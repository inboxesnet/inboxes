# ─── Required ─────────────────────────────────────────────────────────
# Your domain (must point to this server's IP)
DOMAIN=mail.example.com

# Publicly reachable URL of the backend (used for Resend webhook registration)
# MUST be externally reachable — localhost will NOT work in production
# Local dev: use ngrok or Cloudflare Tunnel, then set to that URL
PUBLIC_URL=http://localhost:8080

# ENCRYPTION_KEY must be base64-encoded 32 bytes: openssl rand -base64 32
ENCRYPTION_KEY=
# SESSION_SECRET must be at least 16 characters: openssl rand -hex 32
SESSION_SECRET=

# ─── Database (defaults work with bundled postgres) ───────────────────
POSTGRES_USER=inboxes
# Generate a secure password: openssl rand -hex 16
POSTGRES_PASSWORD=
POSTGRES_DB=inboxes
# DATABASE_URL is constructed automatically in docker-compose.yml
# For bare-metal: DATABASE_URL=postgres://user:pass@localhost:5432/inboxes?sslmode=disable
# WARNING: sslmode=disable is ONLY safe for localhost / Docker-internal connections.
# For remote or cloud databases (RDS, Supabase, Neon), use sslmode=require or sslmode=verify-full.

# ─── Redis (defaults work with bundled redis) ─────────────────────────
# REDIS_URL=redis://redis:6379
# For password-protected Redis: REDIS_URL=redis://:yourpassword@redis:6379
# WARNING: Unauthenticated Redis is ONLY safe for localhost / Docker-internal connections.

# ─── Optional ─────────────────────────────────────────────────────────
# Resend system API key (for sending invite/reset emails from the app itself)
# RESEND_SYSTEM_API_KEY=re_xxx

# Frontend URL (used for email links, default: http://localhost:3000)
# APP_URL=https://mail.yourdomain.com

# Backend port (inside container, no need to change)
# API_PORT=8080

# ─── Frontend (required outside Docker) ───────────────────────────────
# NEXT_PUBLIC_API_URL=https://mail.yourdomain.com
# NEXT_PUBLIC_WS_URL=wss://mail.yourdomain.com

# ─── Backend Workers ─────────────────────────────────────────────────
# TRASH_COLLECTOR_ENABLED=true         # Enable automatic trash purge (default: false)
# EVENT_RETENTION_DAYS=90              # Days to keep WebSocket events (default: 90)
# DOMAIN_HEARTBEAT_INTERVAL=6h        # How often to check Resend domain status (default: 6h)
# TRASH_COLLECTOR_INTERVAL=1h          # How often to purge expired trash (default: 1h)
# EVENT_PRUNER_INTERVAL=6h             # How often to prune old events (default: 6h)
# STATUS_RECOVERY_INTERVAL=5m          # How often to poll Resend for stale statuses (default: 5m)
# GRACE_PERIOD_INTERVAL=1h             # How often to check for expired grace periods (default: 1h)
# STRIPE_EVENT_PRUNER_INTERVAL=6h      # How often to prune old Stripe dedup events (default: 6h)

# ─── WebSocket ──────────────────────────────────────────────────────
# WS_MAX_CONNECTIONS_PER_USER=5       # Max WS connections per user (default: 5)
# WS_TOKEN_CHECK_INTERVAL=1m         # How often to validate WS tokens (default: 1m)
# EVENT_CATCHUP_MAX_AGE=48h           # Max age for event catchup queries (default: 48h)

# ─── Commercial mode only (leave commented for self-hosted) ──────────
# STRIPE_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=
# SYSTEM_FROM_ADDRESS=noreply@yourdomain.com
