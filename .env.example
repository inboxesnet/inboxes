# ─── Required ─────────────────────────────────────────────────────────
# Your domain (must point to this server's IP)
DOMAIN=mail.example.com

# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=
SESSION_SECRET=

# ─── Database (defaults work with bundled postgres) ───────────────────
POSTGRES_USER=inboxes
POSTGRES_PASSWORD=inboxes
POSTGRES_DB=inboxes
# DATABASE_URL is constructed automatically in docker-compose.yml

# ─── Redis (defaults work with bundled redis) ─────────────────────────
# REDIS_URL=redis://redis:6379

# ─── Optional ─────────────────────────────────────────────────────────
# Resend system API key (for sending invite/reset emails from the app itself)
# RESEND_SYSTEM_API_KEY=re_xxx

# Backend port (inside container, no need to change)
# API_PORT=8080
