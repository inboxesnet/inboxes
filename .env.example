# ─── Required ─────────────────────────────────────────────────────────
# Your domain (must point to this server's IP)
DOMAIN=mail.example.com

# ENCRYPTION_KEY must be base64-encoded 32 bytes: openssl rand -base64 32
ENCRYPTION_KEY=
# SESSION_SECRET can be any random string: openssl rand -hex 32
SESSION_SECRET=

# ─── Database (defaults work with bundled postgres) ───────────────────
POSTGRES_USER=inboxes
POSTGRES_PASSWORD=inboxes
POSTGRES_DB=inboxes
# DATABASE_URL is constructed automatically in docker-compose.yml

# ─── Redis (defaults work with bundled redis) ─────────────────────────
# REDIS_URL=redis://redis:6379

# ─── Optional ─────────────────────────────────────────────────────────
# Resend system API key (for sending invite/reset emails from the app itself)
# RESEND_SYSTEM_API_KEY=re_xxx

# Publicly reachable URL of this server (used for Resend webhook registration)
# VPS/Coolify: https://mail.yourdomain.com
# Local dev: use ngrok or Cloudflare Tunnel, then set to that URL
PUBLIC_URL=http://localhost:8080

# Backend port (inside container, no need to change)
# API_PORT=8080
