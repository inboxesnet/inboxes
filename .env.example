# Database
DATABASE_URL="postgresql://user:password@localhost:5432/inboxes?schema=public"

# Resend
RESEND_API_KEY="re_your_api_key_here"
RESEND_WEBHOOK_SECRET="whsec_your_webhook_signing_secret_here"

# Session
SESSION_SECRET="your-session-secret-here-min-32-characters"

# WebSocket
WS_PORT="3001"
WS_HTTP_PORT="3002"
WS_INTERNAL_URL="http://localhost:3002"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"

# Cron Jobs
CRON_SECRET="your-cron-secret-here"

# S3 Storage (for attachments)
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_REGION="us-east-1"
S3_BUCKET="your-bucket-name"
# Optional: For S3-compatible services like MinIO
# S3_ENDPOINT="http://localhost:9000"
# S3_PUBLIC_URL="http://localhost:9000/your-bucket-name"
