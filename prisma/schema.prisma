generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  member
}

enum UserStatus {
  invited
  active
  disabled
}

enum DomainStatus {
  pending
  verified
  active
}

enum Folder {
  inbox
  sent
  archive
  trash
}

enum EmailDirection {
  inbound
  outbound
}

enum EmailStatus {
  received
  sent
  delivered
  bounced
  failed
}

model Org {
  id               String   @id @default(uuid())
  name             String
  catch_all_enabled Boolean @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  users   User[]
  domains Domain[]
  threads Thread[]
  emails  Email[]
  aliases Alias[]
}

model User {
  id               String     @id @default(uuid())
  org_id           String
  email            String     @unique
  name             String
  password_hash    String
  role             UserRole   @default(member)
  status           UserStatus @default(invited)
  invite_token     String?
  invite_expires_at DateTime?
  claimed_at       DateTime?
  reset_token      String?
  reset_token_expires_at DateTime?
  created_at       DateTime   @default(now())
  updated_at       DateTime   @updatedAt

  org         Org         @relation(fields: [org_id], references: [id])
  threads     Thread[]
  emails      Email[]
  alias_users AliasUser[]

  @@index([org_id])
}

model Domain {
  id            String       @id @default(uuid())
  org_id        String
  domain        String       @unique
  status        DomainStatus @default(pending)
  mx_verified   Boolean      @default(false)
  spf_verified  Boolean      @default(false)
  dkim_verified Boolean      @default(false)
  verified_at   DateTime?
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  org Org @relation(fields: [org_id], references: [id])

  @@index([org_id])
}

model Thread {
  id                 String   @id @default(uuid())
  org_id             String
  user_id            String
  subject            String
  participant_emails Json     @default("[]")
  last_message_at    DateTime @default(now())
  message_count      Int      @default(0)
  unread_count       Int      @default(0)
  starred            Boolean  @default(false)
  folder             Folder   @default(inbox)
  deleted_at         DateTime?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  org    Org     @relation(fields: [org_id], references: [id])
  user   User    @relation(fields: [user_id], references: [id])
  emails Email[]

  @@index([org_id])
  @@index([user_id])
  @@index([folder])
  @@index([last_message_at])
}

model Email {
  id                String         @id @default(uuid())
  org_id            String
  thread_id         String
  user_id           String
  message_id        String?
  in_reply_to       String?
  references_header Json?
  from_address      String
  to_addresses      Json           @default("[]")
  cc_addresses      Json           @default("[]")
  bcc_addresses     Json           @default("[]")
  subject           String
  body_html         String         @db.Text
  body_plain        String         @db.Text
  attachments       Json           @default("[]")
  direction         EmailDirection
  status            EmailStatus
  read              Boolean        @default(false)
  starred           Boolean        @default(false)
  folder            Folder         @default(inbox)
  deleted_at        DateTime?
  trash_expires_at  DateTime?
  delivered_via_alias String?
  original_to       String?
  received_at       DateTime       @default(now())
  created_at        DateTime       @default(now())
  search_vector     Unsupported("tsvector")?

  org    Org    @relation(fields: [org_id], references: [id])
  thread Thread @relation(fields: [thread_id], references: [id])
  user   User   @relation(fields: [user_id], references: [id])
  alias  Alias? @relation(fields: [delivered_via_alias], references: [id])

  @@index([user_id])
  @@index([thread_id])
  @@index([org_id])
  @@index([message_id])
  @@index([folder])
  @@index([received_at])
}

model Alias {
  id         String   @id @default(uuid())
  org_id     String
  address    String   @unique
  name       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  org        Org         @relation(fields: [org_id], references: [id])
  alias_users AliasUser[]
  emails     Email[]

  @@index([org_id])
}

model AliasUser {
  id          String   @id @default(uuid())
  alias_id    String
  user_id     String
  can_send_as Boolean  @default(true)
  created_at  DateTime @default(now())

  alias Alias @relation(fields: [alias_id], references: [id])
  user  User  @relation(fields: [user_id], references: [id])

  @@unique([alias_id, user_id])
  @@index([alias_id])
  @@index([user_id])
}
